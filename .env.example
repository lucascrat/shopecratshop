# ============================================
# SHOPCRAT - Environment Variables
# Copie este arquivo para .env.local e preencha
# ============================================

# Database PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret (mínimo 32 chars, gere um aleatório)
JWT_SECRET=seu_jwt_secret_aqui_minimo_32_caracteres

# Cloudflare R2 Storage
R2_ACCESS_KEY_ID=seu_r2_access_key
R2_SECRET_ACCESS_KEY=seu_r2_secret_key
R2_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
NEXT_PUBLIC_R2_PUBLIC_URL=https://seu_bucket_publico.r2.dev
CLOUDFLARE_R2_BUCKET_NAME=nome_do_bucket

# APIs opcionais
GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=
